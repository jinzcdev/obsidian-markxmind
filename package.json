{
  "name": "obsidian-markxmind",
  "version": "0.1.2",
  "description": "An obsidian plugin to render XMindMark syntax as XMind mind maps in `xmind/xmindmark` code blocks.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "lint": "npx eslint .",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "author": "jinzcdev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jinzcdev/obsidian-markxmind.git"
  },
  "homepage": "https://github.com/jinzcdev/obsidian-markxmind",
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "xmind",
    "markxmind",
    "xmindmark",
    "mindmap"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^16.11.6",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.1.9",
    "globals": "^15.13.0",
    "husky": "^9.1.7",
    "prettier": "^3.5.3",
    "prettier-plugin-organize-imports": "^4.1.0",
    "tslib": "2.4.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@markxmind/markxmind-core": "^0.1.0",
    "esbuild": "^0.27.4",
    "obsidian": "latest"
  }
}
